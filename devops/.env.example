# Docker Registry URL
DOCKER_REGISTRY_URL=registry.example.com

# Server configuration
PORT=3001
NODE_ENV=production
JWT_SECRET=change-me-to-a-random-string

# Git identity for agent commits
GIT_USER_NAME=Your Name
GIT_USER_EMAIL=your@email.com

# CORS (production domain)
CORS_ORIGINS=https://swarm.example.com

# Database
DATABASE_URL=postgresql://user:password@host:5432/swarm

# LLM API keys
ANTHROPIC_API_KEY=sk-ant-xxx
OPENAI_API_KEY=sk-xxx
MISTRAL_API_KEY=xxx
OLLAMA_BASE_URL=https://llm.example.com

# Task reminder settings (optional — also configurable via API)
# TASK_REMINDER_INTERVAL_MINUTES=10

# Sandbox & GitHub
SSH_KEYS_HOST_PATH=/home/user/.ssh
GITHUB_TOKEN=ghp_xxx
GITHUB_USER=your-github-username