# ──────────────────────────────────────────────
# PulsarTeam — Environment Variables
# Copy this file to .env and fill in your values
# ──────────────────────────────────────────────

# Server
JWT_SECRET=change-me-to-a-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=swarm2026

# PostgreSQL (used by the bundled postgres container)
POSTGRES_PASSWORD=pulsarteam

# CORS (comma-separated origins). Explicit allow-list — '*' is REJECTED in
# production because the API uses credentials:true (the CORS spec forbids the
# combination, and accepting it would expose authenticated endpoints to any site).
CORS_ORIGINS=http://localhost:5173,http://localhost

# LLM API keys (configure at least one)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
MISTRAL_API_KEY=
OLLAMA_BASE_URL=

# Google OAuth (optional — enables "Sign in with Google" button)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OAuth (optional — enables "Sign in with Microsoft" button)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# Git identity for agent commits
GIT_USER_NAME=PulsarTeam
GIT_USER_EMAIL=agent@pulsarteam.local

# GitHub (optional — for cloning private repos + project activity feed)
# Token requires 'repo' scope for private repos, 'public_repo' for public only
GITHUB_TOKEN=
GITHUB_USER=

# SSH keys path on the host (mounted read-only into containers)
SSH_KEYS_HOST_PATH=/home/youruser/.ssh

# Host code path (parent directory of PulsarTeam, mounted into runner-services)
HOST_CODE_PATH=/home/youruser

# Claude Code runner service (optional — enable with: docker compose --profile coder up -d)
CLAUDE_CODE_OAUTH_TOKEN=
CLAUDE_MODEL=claude-opus-4-6
CLAUDE_MAX_TURNS=50
CODER_API_KEY=change-me-in-production
CODER_PUID=1000
CODER_PGID=1000

# Microsoft Graph integration (OneDrive today; Outlook/Teams/SharePoint in the
# future — they all share ONE Azure App registration and ONE redirect URI; the
# originating plugin is encoded in the OAuth state parameter).
# Register an app at https://entra.microsoft.com → App registrations.
# Redirect URI must point to either:
#   https://your-domain.com/api/microsoft/oauth-redirect  (recommended)
#   https://your-domain.com/microsoft-callback.html       (static frontend page)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_REDIRECT_URI=
MICROSOFT_TENANT_ID=

# Legacy aliases — honored if MICROSOFT_* are unset. The API also accepts
# /api/onedrive/oauth-redirect as a backward-compat callback path.
# ONEDRIVE_CLIENT_ID=
# ONEDRIVE_CLIENT_SECRET=
# ONEDRIVE_REDIRECT_URI=
# ONEDRIVE_TENANT_ID=

# Google integration (Gmail + Drive — optional, per-agent OAuth)
# Gmail and Drive share ONE OAuth client and ONE redirect URI. Set up at:
#   https://console.cloud.google.com/apis/credentials
# Enable both APIs (Gmail + Drive) in the Cloud Console. Register ONE URI:
#   https://your-domain.com/api/google/oauth-redirect  (recommended)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

# Legacy aliases — honored if GOOGLE_* are unset. The API also accepts
# /api/gmail/oauth-redirect, /api/gdrive/oauth-redirect, /gmail-callback.html,
# /gdrive-callback.html as backward-compat callback paths.
# GMAIL_CLIENT_ID=
# GMAIL_CLIENT_SECRET=
# GMAIL_REDIRECT_URI=
# GDRIVE_CLIENT_ID=
# GDRIVE_CLIENT_SECRET=
# GDRIVE_REDIRECT_URI=

# GitHub integration (optional — per-agent OAuth)
# Create an OAuth App at https://github.com/settings/developers
# Set Authorization callback URL to your domain + /github-callback.html
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=
