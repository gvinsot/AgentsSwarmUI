# Docker Registry URL
DOCKER_REGISTRY_URL=registry.methodinfo.fr

# Server configuration
PORT=3001
NODE_ENV=production

# Run agent commands as this OS user (must match host user for volume permissions)
RUN_AS_USER=gildas
RUN_AS_UID=1000
RUN_AS_GID=1000

# Git identity for agent commits
GIT_USER_NAME=Your Name
GIT_USER_EMAIL=your@email.com

# MongoDB connection (ask admin for credentials)
MONGODB_URI=mongodb://user:password@host:27017/agentsswarmui?authSource=admin

# OpenAI / LLM configuration (if needed)
# OPENAI_API_KEY=sk-xxx